{
  "expo": {
    "name": "simplify",
    "slug": "simplify",
    "version": "1.0.0",
    "web": {
      "output": "single",
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "scheme": "simplify",
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true,
      "reactCompiler": true
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./routes"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Roboto/Roboto-Black.ttf",
            "./assets/fonts/Roboto/Roboto-Bold.ttf",
            "./assets/fonts/Roboto/Roboto-ExtraBold.ttf",
            "./assets/fonts/Roboto/Roboto-ExtraLight.ttf",
            "./assets/fonts/Roboto/Roboto-Light.ttf",
            "./assets/fonts/Roboto/Roboto-Medium.ttf",
            "./assets/fonts/Roboto/Roboto-Regular.ttf",
            "./assets/fonts/Roboto/Roboto-SemiBold.ttf",
            "./assets/fonts/Roboto/Roboto-Thin.ttf"
          ]
        }
      ],
      "expo-sqlite"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "owner": "simplify"
  }
}
